#!/usr/bin/env bash
':' //; exec "$(command -v nodejs || command -v node || echo "ERROR node IS NOT AVAILABLE IN THIS SYSTEM")" "$0" "$@"

// shebang hack from:
// http://unix.stackexchange.com/questions/65235/universal-node-js-shebang

// Initially this is run as a shell script.
// Then, the second line, finds nodejs or node or js in the system path
// and executes it with the shell parameters.

// khulnasoft
// real-time performance and health monitoring, done right!
// (C) 2017 Costa Tsaousis <costa@tsaousis.gr>
// SPDX-License-Identifier: GPL-3.0-or-later

// --------------------------------------------------------------------------------------------------------------------

'use strict';

// --------------------------------------------------------------------------------------------------------------------
// get KHULNASOFT environment variables

var KHULNASOFT_PLUGINS_DIR = process.env.KHULNASOFT_PLUGINS_DIR || __dirname;
var KHULNASOFT_USER_CONFIG_DIR = process.env.KHULNASOFT_USER_CONFIG_DIR || '@configdir_POST@';
var KHULNASOFT_STOCK_CONFIG_DIR = process.env.KHULNASOFT_STOCK_CONFIG_DIR || '@libconfigdir_POST@';
var KHULNASOFT_UPDATE_EVERY = process.env.KHULNASOFT_UPDATE_EVERY || 1;
var NODE_D_DIR = KHULNASOFT_PLUGINS_DIR + '/../node.d';

// make sure the modules are found
process.mainModule.paths.unshift(NODE_D_DIR + '/node_modules');
process.mainModule.paths.unshift(NODE_D_DIR);


// --------------------------------------------------------------------------------------------------------------------
// load required modules

var fs = require('fs');
var url = require('url');
var util = require('util');
var http = require('http');
var path = require('path');
var extend = require('extend');
var khulnasoft = require('khulnasoft');


// --------------------------------------------------------------------------------------------------------------------
// configuration

function khulnasoft_read_json_config_file(module_filename) {
    var f = path.basename(module_filename);

    var ufilename, sfilename;

    var m = f.match('.plugin' + '$');
    if(m !== null) {
        ufilename = khulnasoft.options.paths.config + '/' + f.substring(0, m.index) + '.conf';
        sfilename = khulnasoft.options.paths.stock_config + '/' + f.substring(0, m.index) + '.conf';
    }

    m = f.match('.node.js' + '$');
    if(m !== null) {
        ufilename = khulnasoft.options.paths.config + '/node.d/' + f.substring(0, m.index) + '.conf';
        sfilename = khulnasoft.options.paths.stock_config + '/node.d/' + f.substring(0, m.index) + '.conf';
    }

    try {
        khulnasoft.debug('loading module\'s ' + module_filename + ' user-config ' + ufilename);
        return JSON.parse(fs.readFileSync(ufilename, 'utf8'));
    }
    catch(e) {
        khulnasoft.error('Cannot read user-configuration file ' + ufilename + ': ' + e.message + '.');
        dumpError(e);
    }

    try {
        khulnasoft.debug('loading module\'s ' + module_filename + ' stock-config ' + sfilename);
        return JSON.parse(fs.readFileSync(sfilename, 'utf8'));
    }
    catch(e) {
        khulnasoft.error('Cannot read stock-configuration file ' + sfilename + ': ' + e.message + ', using internal defaults.');
        dumpError(e);
    }

    return {};
}

// internal defaults
extend(true, khulnasoft.options, {
    filename: path.basename(__filename),

    update_every: KHULNASOFT_UPDATE_EVERY,

    paths: {
        plugins: KHULNASOFT_PLUGINS_DIR,
        config: KHULNASOFT_USER_CONFIG_DIR,
        stock_config: KHULNASOFT_STOCK_CONFIG_DIR,
        modules: []
    },

    modules_enable_autodetect: true,
    modules_enable_all: true,
    modules: {}
});

// load configuration file
khulnasoft.options_loaded = khulnasoft_read_json_config_file(__filename);
extend(true, khulnasoft.options, khulnasoft.options_loaded);

if(!khulnasoft.options.paths.plugins)
    khulnasoft.options.paths.plugins = KHULNASOFT_PLUGINS_DIR;

if(!khulnasoft.options.paths.config)
    khulnasoft.options.paths.config = KHULNASOFT_USER_CONFIG_DIR;

if(!khulnasoft.options.paths.stock_config)
    khulnasoft.options.paths.stock_config = KHULNASOFT_STOCK_CONFIG_DIR;

// console.error('merged khulnasoft object:');
// console.error(util.inspect(khulnasoft, {depth: 10}));


// apply module paths to node.js process
function applyModulePaths() {
    var len = khulnasoft.options.paths.modules.length;
    while(len--)
        process.mainModule.paths.unshift(khulnasoft.options.paths.modules[len]);
}
applyModulePaths();


// --------------------------------------------------------------------------------------------------------------------
// tracing

function dumpError(err) {
    if (typeof err === 'object') {
        if (err.stack) {
            khulnasoft.debug(err.stack);
        }
    }
}

// --------------------------------------------------------------------------------------------------------------------
// get command line arguments
{
    var found_myself = false;
    var found_number = false;
    var found_modules = false;
    process.argv.forEach(function (val, index, array) {
        khulnasoft.debug('PARAM: ' + val);

        if(!found_myself) {
            if(val === __filename)
                found_myself = true;
        }
        else {
            switch(val) {
                case 'debug':
                    khulnasoft.options.DEBUG = true;
                    khulnasoft.debug('DEBUG enabled');
                    break;

                default:
                    if(found_number === true) {
                        if(found_modules === false) {
                            for(var i in khulnasoft.options.modules)
                                khulnasoft.options.modules[i].enabled = false;
                        }

                        if(typeof khulnasoft.options.modules[val] === 'undefined')
                            khulnasoft.options.modules[val] = {};

                        khulnasoft.options.modules[val].enabled = true;
                        khulnasoft.options.modules_enable_all = false;
                        khulnasoft.debug('enabled module ' + val);
                    }
                    else {
                        try {
                            var x = parseInt(val);
                            if(x > 0) {
                                khulnasoft.options.update_every = x;
                                if(khulnasoft.options.update_every < KHULNASOFT_UPDATE_EVERY) {
                                    khulnasoft.options.update_every = KHULNASOFT_UPDATE_EVERY;
                                    khulnasoft.debug('Update frequency ' + x + 's is too low');
                                }

                                found_number = true;
                                khulnasoft.debug('Update frequency set to ' + khulnasoft.options.update_every + ' seconds');
                            }
                            else khulnasoft.error('Ignoring parameter: ' + val);
                        }
                        catch(e) {
                            khulnasoft.error('Cannot get value of parameter: ' + val);
                            dumpError(e);
                        }
                    }
                    break;
            }
        }
    });
}

if(khulnasoft.options.update_every < 1) {
    khulnasoft.debug('Adjusting update frequency to 1 second');
    khulnasoft.options.update_every = 1;
}

// --------------------------------------------------------------------------------------------------------------------
// find modules

function findModules() {
    var found = 0;

    var files = fs.readdirSync(NODE_D_DIR);
    var len = files.length;
    while(len--) {
        var m = files[len].match('.node.js' + '$');
        if(m !== null) {
            var n = files[len].substring(0, m.index);

            if(typeof(khulnasoft.options.modules[n]) === 'undefined')
                khulnasoft.options.modules[n] = { name: n, enabled: khulnasoft.options.modules_enable_all };

            if(khulnasoft.options.modules[n].enabled === true) {
                khulnasoft.options.modules[n].name = n;
                khulnasoft.options.modules[n].filename = NODE_D_DIR + '/' + files[len];
                khulnasoft.options.modules[n].loaded = false;

                // load the module
                try {
                    khulnasoft.debug('loading module ' + khulnasoft.options.modules[n].filename);
                    khulnasoft.options.modules[n].module = require(khulnasoft.options.modules[n].filename);
                    khulnasoft.options.modules[n].module.name = n;
                    khulnasoft.debug('loaded module ' + khulnasoft.options.modules[n].name + ' from ' + khulnasoft.options.modules[n].filename);
                }
                catch(e) {
                    khulnasoft.options.modules[n].enabled = false;
                    khulnasoft.error('Cannot load module: ' + khulnasoft.options.modules[n].filename + ' exception: ' + e);
                    dumpError(e);
                    continue;
                }

                // load its configuration
                var c = {
                    enable_autodetect: khulnasoft.options.modules_enable_autodetect,
                    update_every: khulnasoft.options.update_every
                };

                var c2 = khulnasoft_read_json_config_file(files[len]);
                extend(true, c, c2);

                // call module auto-detection / configuration
                try {
                    khulnasoft.modules_configuring++;
                    khulnasoft.debug('Configuring module ' + khulnasoft.options.modules[n].name);
                    var serv = khulnasoft.configure(khulnasoft.options.modules[n].module, c, function() {
                        khulnasoft.debug('Configured module ' + khulnasoft.options.modules[n].name);
                        khulnasoft.modules_configuring--;
                    });

                    khulnasoft.debug('Configuring module ' + khulnasoft.options.modules[n].name + ' reports ' + serv + ' eligible services.');
                }
                catch(e) {
                    khulnasoft.modules_configuring--;
                    khulnasoft.options.modules[n].enabled = false;
                    khulnasoft.error('Failed module auto-detection: ' + khulnasoft.options.modules[n].name + ' exception: ' + e + ', disabling module.');
                    dumpError(e);
                    continue;
                }

                khulnasoft.options.modules[n].loaded = true;
                found++;
            }
        }
    }

    // khulnasoft.debug(khulnasoft.options.modules);
    return found;
}

if(findModules() === 0) {
    khulnasoft.error('Cannot load any .node.js module from: ' + NODE_D_DIR);
    khulnasoft.disableNodePlugin();
    process.exit(1);
}


// --------------------------------------------------------------------------------------------------------------------
// start

function start_when_configuring_ends() {
    if(khulnasoft.modules_configuring > 0) {
        khulnasoft.debug('Waiting modules configuration, still running ' + khulnasoft.modules_configuring);
        setTimeout(start_when_configuring_ends, 500);
        return;
    }

    khulnasoft.modules_configuring = 0;
    khulnasoft.start();
}
start_when_configuring_ends();

//khulnasoft.debug('khulnasoft object:')
//khulnasoft.debug(khulnasoft);
